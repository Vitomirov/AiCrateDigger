# Copy to .env in the repo root (never commit real secrets).
# Docker Compose passes these into backend / frontend services.

# --- Required for full pipeline ---
OPENAI_API_KEY=
TAVILY_API_KEY=

# --- Optional ---
DISCOGS_TOKEN=

# Postgres (Compose default matches docker-compose.yml backend service)
# DATABASE_URL=postgresql+asyncpg://aicratedigger:aicratedigger@db:5432/aicratedigger

# Backend
DEBUG=false
# LOG_LEVEL=INFO
# LOG_FORMAT=human

# Frontend → backend (browser vs server proxy)
# NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
# BACKEND_URL=http://localhost:8000
