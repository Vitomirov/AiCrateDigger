# Copy to .env in the repo root (never commit real secrets).
# docker-compose.yml loads ONLY this file — no hardcoded URLs in Compose.

# --- Required for full pipeline ---
OPENAI_API_KEY=
TAVILY_API_KEY=

# --- Optional ---
# (none required beyond API keys above)

# --- Postgres (db service + backend) ---
POSTGRES_USER=aicratedigger
POSTGRES_PASSWORD=aicratedigger
POSTGRES_DB=aicratedigger
# Host port published on your machine (maps to 5432 inside the db container)
POSTGRES_PORT=5433

# Backend DSN — set ONE of:
# (A) Full URL (recommended):
DATABASE_URL=postgresql+asyncpg://aicratedigger:aicratedigger@db:5432/aicratedigger
# (B) Or omit DATABASE_URL and set host/port for Docker network / local dev:
# POSTGRES_HOST=db
# POSTGRES_PORT=5432

# Local poetry/uvicorn on the host (not inside Compose):
# DATABASE_URL=postgresql+asyncpg://aicratedigger:aicratedigger@localhost:5433/aicratedigger

# --- Redis ---
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# --- Backend ---
DEBUG=false
# Set false while iterating locally; enable on staging/production.
SEARCH_RATE_LIMIT_ENABLED=true
# When true (default), missing Redis blocks /search and /parse with 503.
SEARCH_RATE_LIMIT_FAIL_CLOSED=true
# Optional overrides (defaults: 5 requests / 86400 seconds, shared across /search and /parse):
# SEARCH_RATE_LIMIT_MAX_REQUESTS=5
# SEARCH_RATE_LIMIT_WINDOW_SECONDS=86400
# SEARCH_QUERY_MAX_LENGTH=512
# BFF shared secret — same value on backend + frontend. Unset = local dev bypass (do not use in production).
INTERNAL_API_SECRET=dev-change-me-before-production
# Account-wide daily caps (UTC reset). 0 = unlimited for that bucket.
GLOBAL_DAILY_QUOTA_ENABLED=true
GLOBAL_DAILY_QUOTA_FAIL_CLOSED=true
# GLOBAL_DAILY_QUOTA_PARSE_MAX=500
# GLOBAL_DAILY_QUOTA_TAVILY_MAX=200
# GLOBAL_DAILY_QUOTA_OPENAI_EXTRACT_MAX=300
LOG_LEVEL=INFO
LOG_FORMAT=human

# --- Frontend (open http://localhost:3000 in the browser — not :8000) ---
BACKEND_URL=http://backend:8000
# SSR health checks only — do not call /search or /parse from the browser against this URL.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
FRONTEND_PUBLIC_URL=http://localhost:3000
# Must match INTERNAL_API_SECRET when the secret is set (Compose loads the same .env for both services).
# INTERNAL_API_SECRET is read by Next.js Route Handlers (server-only, not NEXT_PUBLIC_*).
